## Copy this file to local.properties and fill in your values.
## local.properties is in .gitignore — never commit it.

sdk.dir=/path/to/Android/sdk

# Release signing config
release.storeFile=/path/to/release.keystore
release.storePassword=YOUR_STORE_PASSWORD
release.keyAlias=YOUR_KEY_ALIAS
release.keyPassword=YOUR_KEY_PASSWORD

# Google OAuth Web Client ID (from Firebase Console → Authentication → Sign-in method → Google)
GOOGLE_WEB_CLIENT_ID=YOUR_GOOGLE_WEB_CLIENT_ID.apps.googleusercontent.com
